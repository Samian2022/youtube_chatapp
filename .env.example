# Gemini API (required for chat)
# Get at https://aistudio.google.com/apikey
REACT_APP_GEMINI_API_KEY=your_gemini_api_key

# MongoDB Atlas connection string (required)
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/
REACT_APP_MONGODB_URI=your_mongodb_connection_string

# YouTube Data API v3 (for YouTube Channel Download tab)
# Get at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key

# Optional: OpenAI API key for generateImage (DALL-E). If unset, a placeholder image is used.
OPENAI_API_KEY=your_openai_api_key
